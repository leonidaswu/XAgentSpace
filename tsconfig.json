{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "types": [
      "node"
    ],
    "baseUrl": "."
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "tests/**/*.ts",
    "types/**/*.d.ts",
    "scripts/**/*.ts",
    "scripts/**/*.mjs"
  ]
}
